{
  "name": "swiftav-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "pnpm": ">=10.0.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter @swiftav/infrastructure-web dev",
    "build": "pnpm --recursive --filter \"@swiftav/*\" build",
    "build:entities": "pnpm --filter @swiftav/entities build",
    "build:use-cases": "pnpm --filter @swiftav/use-cases build",
    "build:interface-adapters": "pnpm --filter @swiftav/interface-adapters build",
    "build:infrastructure-media": "pnpm --filter @swiftav/infrastructure-media build",
    "build:infrastructure-render": "pnpm --filter @swiftav/infrastructure-render build",
    "build:infrastructure-storage": "pnpm --filter @swiftav/infrastructure-storage build",
    "build:infrastructure-web": "pnpm --filter @swiftav/infrastructure-web build",
    "lint": "pnpm --recursive --filter \"*\" lint",
    "preview": "pnpm --filter @swiftav/infrastructure-web preview",
    "clean": "pnpm --recursive --filter \"*\" exec rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
