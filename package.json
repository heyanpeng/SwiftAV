{
  "name": "swiftav-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "pnpm": ">=10.0.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter @swiftav/infra-web dev",
    "build": "pnpm --recursive --filter \"@swiftav/*\" build",
    "build:entities": "pnpm --filter @swiftav/entities build",
    "build:usecases": "pnpm --filter @swiftav/usecases build",
    "build:adapters": "pnpm --filter @swiftav/adapters build",
    "build:infra-media": "pnpm --filter @swiftav/infra-media build",
    "build:infra-render": "pnpm --filter @swiftav/infra-render build",
    "build:infra-storage": "pnpm --filter @swiftav/infra-storage build",
    "build:infra-web": "pnpm --filter @swiftav/infra-web build",
    "lint": "pnpm --recursive --filter \"*\" lint",
    "preview": "pnpm --filter @swiftav/infra-web preview",
    "clean": "pnpm --recursive --filter \"*\" exec rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
